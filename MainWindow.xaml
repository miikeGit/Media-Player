<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MediaPlayer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MediaPlayer"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="MediaPlayer">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base"/>
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <SwapChainPanel x:Name="SwapChainCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" SizeChanged="SwapChainCanvasSizeChanged"/>
        <Border x:Name="SubtitleBorder"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="0,0,0,160" 
                Padding="16,8"
                CornerRadius="8"
                Background="#A6000000"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <TextBlock x:Name="SubtitleText"
                       Foreground="White"
                       FontSize="24"
                       FontWeight="SemiBold"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="800"/>
        </Border>
        <Grid x:Name="MainUI">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <MenuBar>
                <MenuBarItem Title="File">
                    <MenuFlyoutItem Text="Open file" Click="OnOpenFileClick"/>
                    <MenuFlyoutItem Text="Play from URL" Click="OnOpenUrlClick"/>
                    <MenuFlyoutItem Text="Play from .zip archive" Click="OnPlayFromZipClick"/>
                    <MenuFlyoutItem Text="Play from magnet" Click="OnPlayFromMagnetClick"/>
                    <MenuFlyoutItem Text="Play from tracker" Click="OnPlayFromTrackerClick"/>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem Text="Exit" Click="OnExitClick"/>
                </MenuBarItem>

                <MenuBarItem Title="Capture">
                    <MenuFlyoutItem Text="Save screenshot" Click="OnSaveScreenshotClick"/>
                    <MenuFlyoutItem x:Name="ClipRecordButton" Text="Start recording" Click="OnClipRecordClick"/>
                </MenuBarItem>

                <MenuBarItem Title="VFX">
                    <RadioMenuFlyoutItem Tag="Normal" Text="Normal" GroupName="VFXGroup" Click="OnEffectItemClick" IsChecked="True" />
                    <RadioMenuFlyoutItem Tag="Grayscale" Text="Grayscale" GroupName="VFXGroup" Click="OnEffectItemClick"/>
                </MenuBarItem>

                <MenuBarItem Title="SFX">
                    <RadioMenuFlyoutItem Tag="Normal" Text="Normal" GroupName="SFXGroup" Click="OnAudioEffectItemClick" IsChecked="True"/>
                    <RadioMenuFlyoutItem Tag="Reverb" Text="Reverb" GroupName="SFXGroup" Click="OnAudioEffectItemClick"/>
                </MenuBarItem>

                <MenuBarItem Title="Accessibility">
                    <MenuFlyoutItem Text="Load subtitles" Click="OnOpenSubtitleFile"/>
                </MenuBarItem>
            </MenuBar>

            <Grid Grid.Row="1" Padding="16,12">
                <TextBlock HorizontalAlignment="Center" x:Name="MediaTitle" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center"/>

                <Button HorizontalAlignment="Right" Click="OnTogglePlaylistClick" Background="Transparent" BorderBrush="Transparent" CornerRadius="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="List"/>
                        <TextBlock Text="Playlist"/>
                    </StackPanel>
                </Button>
            </Grid>

            <SplitView x:Name="PlaylistSplitView" Grid.Row="2" DisplayMode="Overlay" PanePlacement="Right">
                <SplitView.Pane>
                    <Grid Padding="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="Playlist" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="8">
                                <Button Click="OnAddToPlaylistClick" ToolTipService.ToolTip="Add new">
                                    <SymbolIcon Symbol="Add"/>
                                </Button>
                                <Button ToolTipService.ToolTip="Clear">
                                    <SymbolIcon Symbol="Delete"/>
                                    <Button.Flyout>
                                        <Flyout>
                                            <StackPanel>
                                                <TextBlock Style="{ThemeResource BaseTextBlockStyle}" Text="All items will be removed. Do you want to continue?" Margin="0,0,0,12" />
                                                <Button Click="OnClearPlaylistClick" Content="Clear" />
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>

                                </Button>
                            </StackPanel>
                        </Grid>
                        <ListView x:Name="PlaylistView" Grid.Row="1" SelectionChanged="OnPlaylistSelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Grid Padding="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>
                                        <Button Grid.Column="1" ToolTipService.ToolTip="Remove from playlist" Click="OnRemoveFromPlaylistClick">
                                            <SymbolIcon Symbol="Clear" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </SplitView.Pane>

                <SplitView.Content>
                    <Grid>
                        <Border VerticalAlignment="Bottom" Padding="20,16" Background="#B30F0F0F" BorderBrush="#26FFFFFF" BorderThickness="1">
                            <StackPanel Spacing="16">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="CurrentTimeText" Text="0:00" VerticalAlignment="Center" Grid.Column="0" Margin="0,0,16,0" FontFamily="Consolas" Opacity="0.8" Foreground="White"/>
                                    <Slider x:Name="TimeSlider" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center" IsThumbToolTipEnabled="False" 
                                        PointerEntered="OnSliderPointerEntered"
                                        PointerMoved="OnSliderPointerMoved"
                                        PointerExited="OnSliderPointerExited" Margin="0,-4,0,-4"/>
                                    <Popup x:Name="ThumbnailPopup" IsHitTestVisible="False" VerticalOffset="-100">
                                        <Border CornerRadius="6" BorderBrush="#33FFFFFF" BorderThickness="1" Background="#FF1C1C1C" Padding="1" Margin="0,0,0,4">
                                            <Image x:Name="ThumbnailImage" Width="160" Height="90" Stretch="UniformToFill"/>
                                        </Border>
                                    </Popup>
                                    <TextBlock x:Name="DurationText" Text="0:00" VerticalAlignment="Center" Grid.Column="2" Margin="16,0,0,0" FontFamily="Consolas" Opacity="0.8" Foreground="White"/>
                                </Grid>

                                <Grid VerticalAlignment="Bottom">
                                    <Grid.KeyboardAccelerators>
                                        <KeyboardAccelerator Key="Up" Invoked="OnVolumeUp"/>
                                        <KeyboardAccelerator Key="Down" Invoked="OnVolumeDown"/>
                                        <KeyboardAccelerator Key="Space" Invoked="OnPlayPauseKey"/>
                                    </Grid.KeyboardAccelerators>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Button x:Name="TempoButton" Content="1x" Background="Transparent" BorderBrush="Transparent" CornerRadius="4" Foreground="White">
                                            <Button.Flyout>
                                                <MenuFlyout>
                                                    <RadioMenuFlyoutItem Text="0.25x" Tag="0.25" GroupName="Speed" Click="OnTempoItemClick"/>
                                                    <RadioMenuFlyoutItem Text="0.5x"  Tag="0.5"  GroupName="Speed" Click="OnTempoItemClick"/>
                                                    <RadioMenuFlyoutItem Text="0.75x" Tag="0.75" GroupName="Speed" Click="OnTempoItemClick"/>
                                                    <RadioMenuFlyoutItem Text="1x"    Tag="1"    GroupName="Speed" Click="OnTempoItemClick" IsChecked="True"/>
                                                    <RadioMenuFlyoutItem Text="1.25x" Tag="1.25" GroupName="Speed" Click="OnTempoItemClick"/>
                                                    <RadioMenuFlyoutItem Text="1.5x"  Tag="1.5"  GroupName="Speed" Click="OnTempoItemClick"/>
                                                    <RadioMenuFlyoutItem Text="1.75x" Tag="1.75" GroupName="Speed" Click="OnTempoItemClick"/>
                                                    <RadioMenuFlyoutItem Text="2x"    Tag="2"    GroupName="Speed" Click="OnTempoItemClick"/>
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>
                                        <Button Click="OnTogglePipClick" ToolTipService.ToolTip="Picture in Picture" Background="Transparent" BorderBrush="Transparent" CornerRadius="4" Padding="7" Margin="0,0,12,0" Foreground="White">
                                            <SymbolIcon>BackToWindow</SymbolIcon>
                                        </Button>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
                                        <Button Click="OnPreviousBtnClick" ToolTipService.ToolTip="Previous" Background="Transparent" BorderBrush="Transparent" CornerRadius="24" Width="48" Height="48" Foreground="White">
                                            <SymbolIcon Symbol="Previous"/>
                                        </Button>
                                        <Button x:Name="PlayPause" Click="OnPlayPauseBtnClick" ToolTipService.ToolTip="Toggle playback" CornerRadius="28" Width="56" Height="56">
                                            <SymbolIcon Symbol="Play" x:Name="PlayPauseIcon"/>
                                        </Button>
                                        <Button Click="OnNextBtnClick" ToolTipService.ToolTip="Next" Background="Transparent" BorderBrush="Transparent" CornerRadius="24" Width="48" Height="48" Foreground="White">
                                            <SymbolIcon Symbol="Next"/>
                                        </Button>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4" VerticalAlignment="Center">
                                        <FontIcon x:Name="VolumeIcon" Glyph="&#xE995;" VerticalAlignment="Center" Foreground="White" Margin="0,0,4,0" FontSize="16"/>
                                        <Slider x:Name="VolumeSlider" Minimum="0" Maximum="100" Value="100" Width="100" ValueChanged="OnVolumeSliderValueChanged" IsThumbToolTipEnabled="False" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="VolumeText" Text="100" VerticalAlignment="Center" Width="30" TextAlignment="Right" FontFamily="Consolas" Opacity="0.8" Foreground="White"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </SplitView.Content>
            </SplitView>
        </Grid>

        <Grid x:Name="PipUI" Visibility="Collapsed" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,10">
            <Border Background="#B30F0F0F" BorderBrush="#26FFFFFF" BorderThickness="1" CornerRadius="30" Padding="8,8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Click="OnPlayPauseBtnClick" Background="Transparent" BorderBrush="Transparent" CornerRadius="20" Width="45" Height="45" Foreground="White">
                        <SymbolIcon Symbol="Play" x:Name="PipPlayPauseIcon"/>
                    </Button>
                    <Button Click="OnTogglePipClick" Background="Transparent" BorderBrush="Transparent" CornerRadius="20" Width="45" Height="45" Foreground="White">
                        <SymbolIcon Symbol="FullScreen"/>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>